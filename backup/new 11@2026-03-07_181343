class Color(int):
    """
    The parent class int is immutable, so its value is set during object creation (__new__) rather than initialization (__init__). Any attempt to modify its value in the __init__ method will fail.
    The __new__ method is responsible for creating and returning a new instance of the class, for immutable types like int.
    """
    def __new__(cls, color):
        return super().__new__(cls, color & 0xffffff)        
        
    def __iadd__(self, other):
        return Color((int(self) + other) & 0xffffff)
    def __isub__(self, other):
        return Color((int(self) - other) & 0xffffff)
    def __imul__(self, other):
        return Color((int(self) * other) & 0xffffff)
    def __idiv__(self, other):
        return Color((int(self) // other)& 0xffffff)
    def __ifloordiv__(self, other):
        return Color((int(self) // other)& 0xffffff)
        
    def __add__(self, other):
        return Color((int(self) + other) & 0xffffff)
    def __sub__(self, other):
        return Color((int(self) - other) & 0xffffff)
    def __mul__(self, other):
        return Color((int(self) * other) & 0xffffff)
    def __div__(self, other):
        return Color((int(self) // other)& 0xffffff)
    def __floordiv__(self, other):
        return Color((int(self) // other)& 0xffffff)
    
    def __str__(self):
        return '#' + f'{(self & 0xff0000) >> 16:02x}'+ \
                     f'{(self & 0x00ff00) >> 8:02x}'+ \
                     f'{(self & 0x0000ff):02x}'
    __repr__ = __str__




def tree(lvl, step=150):
    gray_value = int((lvl / MAX_LVL) * 255)
    color = Color((gray_value << 16) + (gray_value << 8) + gray_value)
    # print(lvl, color)
    
    if lvl == 0:
        pendown()
        forward(step)
        penup()
    else:
        s2 = step * .707107
        pendown()
        forward(step)
        penup()
        left(45)
        tree(lvl-1, s2)
        back(s2)
        left(-45)
        left(-45)
        tree(lvl-1, s2)
        back(s2)
        left(45)





