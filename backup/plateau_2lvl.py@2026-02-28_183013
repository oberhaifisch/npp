# given a list of random digits. # A plateau is a consecutive group, starting when diff between next and prev digit is greater than 1.# The task is to decrease all the plateaus, so all these differences were leq 1# Eg for these digits# 00123210023202356532000# this # 00000000011101122211000# is the plateau map, where the number shows a plateau level. # The result need to be:# 00123210012101234332000# Write a python codetext = '1233323451224554123' #                   vvvv                  gt   = '1233323451223443123' text = '00123210023202356532000' #                   vvvv                  gt   = '00123210012101234332000' print(text)text = list(map(int, text))diffs = []mems  = []fc = 0  # flag_correctingmem = Nonei = 1while 1:    print(fc + 0, end='')    diff = text[i] - text[i-1]    if diff > 1:        diffs.append(diff)        mems.append(text[i])            if fc:        if text[i] == mems[-1]:            mems.pop()            diff = diffs.pop()                    fc = 0        text[i] -= diff - 1    else:        diff = text[i] - text[i-1]        fc = diff > 1        if fc:            mem = text[i]            text[i] -= diff - 1                i += 1    if i == len(text):        breakprint()    print(*text, sep='')print(gt)print(''.join(map(str, text)) == gt)