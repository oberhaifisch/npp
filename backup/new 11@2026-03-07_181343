def grid(x0=-150, y0=-150, x1=200, y1=200, step=10, grid_color="#ffbf00"):
    # Функция для рисования вертикальных линий сетки
    def draw_y_lines(step):
        tracer(0)
        for i in range(x0, x1+1, step):
            penup()
            goto(i, y1)
            pendown()
            goto(i, y0)
        tracer(1)


    # Функция для рисования горизонтальных линий сетки
    def draw_x_lines(step):
        tracer(0)
        for i in range(y0, y1+1, step):
            penup()
            goto(x1, i)
            pendown()
            goto(x0, i)
        tracer(1)


    # скорость черепахи

    # цвет сетки
    color(grid_color)

    # Отображение сетки
    pensize(1)
    draw_y_lines(step)
    draw_x_lines(step)
    pensize(3)
    draw_y_lines(step * 10)
    draw_x_lines(step * 10)

    # Возвращаем черепашку в начало координат
    penup()
    home()
    pendown()
    color("#000000")
    pensize(1)

