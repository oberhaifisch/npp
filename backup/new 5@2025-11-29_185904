import pygame
import random
import math
import numpy as np
from pygame import gfxdraw

# Initialize pygame
pygame.init()

# Constants
WIDTH, HEIGHT = 800, 600
FPS = 60
DRONE_COUNT = 30
NEIGHBOR_RADIUS = 50
DESIRED_DISTANCE = 20
MAX_SPEED = 2
TARGET = (WIDTH // 2, HEIGHT // 2)
FAILURE_RATE = 0.001  # Probability a drone fails each frame

# Colors
WHITE = (255, 255, 255)
BLACK = (0, 0, 0)
BLUE = (0, 0, 255)
RED = (255, 0, 0)
GREEN = (0, 255, 0)
GRAY = (150, 150, 150)

class Drone:
    def __init__(self, id, x=None, y=None):
        self.id = id
        self.radius = 5

        # Random initial position if not provided
        if x is None or y is None:
            self.x = random.randint(50, WIDTH - 50)
            self.y = random.randint(50, HEIGHT - 50)
        else:
            self.x = x
            self.y = y

        # Initial velocity
        self.vx = random.uniform(-1, 1)
        self.vy = random.uniform(-1, 1)

        self.active = True
        self.color = BLUE

    def distance_to(self, other):
        return math.sqrt((self.x - other.x)**2 + (self.y - other.y)**2)

    def update(self, neighbors, target):
        if not self.active:
            return

        # Initialize forces
        repulsion_x, repulsion_y = 0, 0
        attraction_x, attraction_y = 0, 0
        striving_x, striving_y = 0, 0

        # Rule 1: Collision avoidance
        for neighbor in neighbors:
            dist = self.distance_to(neighbor)
            if dist < DESIRED_DISTANCE:
                # Strong repulsion when too close
                k = (DESIRED_DISTANCE / dist)**3
                dx = self.x - neighbor.x
                dy = self.y - neighbor.y
                repulsion_x += (dx / dist) * k
                repulsion_y += (dy / dist) * k

        # Rule 2: Group cohesion
        if len(neighbors) > 0:
            for neighbor in neighbors:
                dist = self.distance_to(neighbor)
                if dist > DESIRED_DISTANCE * 1.2:
                    # Attraction to neighbors that are too far
                    k = 0.1 * DESIRED_DISTANCE / (dist - DESIRED_DISTANCE)
                    dx = neighbor.x - self.x
                    dy = neighbor.y - self.y
                    attraction_x += k * dx / dist
                    attraction_y += k * dy / dist

        # Rule 3: Movement toward target
        target_dist = math.sqrt((self.x - target[0])**2 + (self.y - target[1])**2)
        if target_dist > 0:
            k = 0.01  # Strength of target attraction
            striving_x = (target[0] - self.x) * k
            striving_y = (target[1] - self.y) * k

        # Combine all forces
        self.vx += repulsion_x + attraction_x + striving_x
        self.vy += repulsion_y + attraction_y + striving_y

        # Limit speed
        speed = math.sqrt(self.vx**2 + self.vy**2)
        if speed > MAX_SPEED:
            self.vx = (self.vx / speed) * MAX_SPEED
            self.vy = (self.vy / speed) * MAX_SPEED

        # Update position
        self.x += self.vx
        self.y += self.vy

        # Keep drones within bounds
        self.x = max(self.radius, min(WIDTH - self.radius, self.x))
        self.y = max(self.radius, min(HEIGHT - self.radius, self.y))

    def draw(self, screen):
        if self.active:
            # Draw drone body
            pygame.draw.circle(screen, self.color, (int(self.x), int(self.y)), self.radius)

            # Draw velocity vector
            end_x = self.x + self.vx * 5
            end_y = self.y + self.vy * 5
            pygame.draw.line(screen, BLACK, (self.x, self.y), (end_x, end_y), 1)
        else:
            # Draw failed drone
            pygame.draw.circle(screen, GRAY, (int(self.x), int(self.y)), self.radius)

class Swarm:
    def __init__(self, drone_count):
        self.drones = [Drone(i) for i in range(drone_count)]
        self.neighbor_radius = NEIGHBOR_RADIUS
        self.failure_rate = FAILURE_RATE
        self.target = TARGET

    def find_neighbors(self, drone):
        neighbors = []
        for d in self.drones:
            if d.active and d != drone and drone.distance_to(d) < self.neighbor_radius:
                neighbors.append(d)
        return neighbors

    def simulate_failure(self):
        for drone in self.drones:
            if drone.active and random.random() < self.failure_rate:
                drone.active = False
                drone.color = RED

    def update(self):
        self.simulate_failure()

        for drone in self.drones:
            if drone.active:
                neighbors = self.find_neighbors(drone)
                drone.update(neighbors, self.target)

    def draw(self, screen):
        # Draw target
        pygame.draw.circle(screen, GREEN, self.target, 10)
        pygame.draw.line(screen, GREEN, (self.target[0]-10, self.target[1]),
                         (self.target[0]+10, self.target[1]), 2)
        pygame.draw.line(screen, GREEN, (self.target[0], self.target[1]-10),
                         (self.target[0], self.target[1]+10), 2)

        # Draw drones
        for drone in self.drones:
            drone.draw(screen)

        # Draw neighbor radius for selected drone (if any)
        if hasattr(self, 'selected_drone') and self.selected_drone:
            pygame.draw.circle(screen, (200, 200, 200),
                              (int(self.selected_drone.x), int(self.selected_drone.y)),
                              self.neighbor_radius, 1)

def main():
    screen = pygame.display.set_mode((WIDTH, HEIGHT))
    pygame.display.set_caption("Swarm Intelligence Simulation")
    clock = pygame.time.Clock()
    font = pygame.font.SysFont('Arial', 16)

    swarm = Swarm(DRONE_COUNT)
    running = True
    show_info = True
    selected_drone = None

    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
            elif event.type == pygame.KEYDOWN:
                if event.key == pygame.K_i:
                    show_info = not show_info
                elif event.key == pygame.K_r:
                    # Reset simulation
                    swarm = Swarm(DRONE_COUNT)
                    selected_drone = None
            elif event.type == pygame.MOUSEBUTTONDOWN:
                # Select a drone
                mouse_x, mouse_y = pygame.mouse.get_pos()
                for drone in swarm.drones:
                    if drone.active and drone.distance_to(Drone(-1, mouse_x, mouse_y)) < drone.radius:
                        selected_drone = drone
                        swarm.selected_drone = drone
                        break
                else:
                    selected_drone = None
                    swarm.selected_drone = None

        # Update swarm
        swarm.update()

        # Draw
        screen.fill(WHITE)
        swarm.draw(screen)

        # Display info
        if show_info:
            info_text = [
                f"Drones: {sum(1 for d in swarm.drones if d.active)}/{len(swarm.drones)}",
                f"FPS: {int(clock.get_fps())}",
                "Controls:",
                "I - Toggle info",
                "R - Reset simulation",
                "Click - Select drone"
            ]

            for i, text in enumerate(info_text):
                text_surface = font.render(text, True, BLACK)
                screen.blit(text_surface, (10, 10 + i * 20))

        pygame.display.flip()
        clock.tick(FPS)

    pygame.quit()

if __name__ == "__main__":
    main()