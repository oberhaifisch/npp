smallest = -1
count = 0
suma = 0
b = []
c = []
while 1:
    a = input().split()
    if len(a) == 0:
        break
    for i in a:
        if int(i) % 2 == 0:
            c.append(int(i))
    for i in a:
        if i[-1] == "7" or i[-1] == "3":
            count += 1
        suma += int(i)
    if suma % 2 != 0:
        b.append(suma)
    suma = 0
    b.append(min(c))
if len(b) == 0:
    suma = -1
print({'count': count, 'smallest': smallest, 'sum': max(b)})